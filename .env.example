# Required
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=...
TAVILY_API_KEY=tvly-...
VOYAGE_API_KEY=pa-...

# Optional
SQLITE_DB_PATH=./data/urvar.db
CLAUDE_MODEL=claude-sonnet-4-6
HISTORY_TURNS=10
MAX_AGENT_ITERATIONS=8
# TELEGRAM_GROUP_ID=         # set to enable /report and the Monday weekly briefing

# Auto-learning knowledge base
# OWNER_TELEGRAM_ID=         # Telegram user id allowed to approve learned facts; unset = learning degrades (proposals stay pending)
KB_LEARNING_ENABLED=true     # set false to disable /teach + conversation/web/periodic distillation
KB_DISTILL_CRON=0 8 * * *    # periodic distillation schedule (IST); default daily 08:00
